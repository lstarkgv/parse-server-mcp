# Parse Server MCP Server Configuration
# Copia este archivo a .env y configura tus valores

# Parse Server Configuration
PARSE_SERVER_URL=http://localhost:1338/api
APP_ID=fentasticAPI
MASTER_KEY=test

# Opcional: Timeout para requests (en milisegundos)
# REQUEST_TIMEOUT=30000

# MCP Server Configuration
# Puerto del servidor MCP en modo HTTP (default: 3001)
MCP_PORT=3001

# Parse Server Project Path (opcional)
# Ruta absoluta a tu proyecto Parse Server para crear migraciones automáticamente
# Ejemplo: PARSE_PROJECT_PATH=/Users/usuario/proyectos/mi-parse-server
# PARSE_PROJECT_PATH=/path/to/your/parse/server/project
